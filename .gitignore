# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*

/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode/*
!/.vscode/extensions.json
/coverage
/dist
/node_modules
/platforms
/plugins
/www

# Variáveis de ambiente — .env.production e .env.example vão no repo (sem segredos)
.env
.env.*
!.env.example
!.env.production

# Diretório-lixo de projeto não relacionado (caiu aqui por engano)
UsersasdasAppDataLocalTempcontent-cosmos-app/
